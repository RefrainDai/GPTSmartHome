# Backend server
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=*

# Voice recognition
VOICE_RECOGNITION_MODE=google
VOICE_LANGUAGE=zh-CN
VOICE_SAMPLE_RATE=16000
VOICE_CHUNK_SECONDS=2.8
VOICE_RMS_THRESHOLD=0.015

# LLM intent parsing. Compatible with OpenAI-style chat completion APIs.
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_AUTH_HEADER=authorization
LLM_MAX_COMPLETION_TOKENS=512

# Xiaomi MiMo Token Plan OpenAI-compatible examples.
# Token Plan keys usually start with tp- and use the api-key header.
# LLM_ENABLED=true
# LLM_API_KEY=your_xiaomi_tokenplan_api_key
# LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# LLM_AUTH_HEADER=api-key
# LLM_MODEL=mimo-v2-flash
# Other Token Plan regions:
# LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# LLM_BASE_URL=https://token-plan-ams.xiaomimimo.com/v1

# TTS: edge, pyttsx3, or none
TTS_ENABLED=true
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# Speaker verification
SPEAKER_VERIFY_ENABLED=false
SPEAKER_THRESHOLD=0.82

# Gesture recognition
GESTURE_CAMERA_INDEX=0
GESTURE_COOLDOWN_SECONDS=2.0
GESTURE_FRAME_WIDTH=424
GESTURE_FRAME_HEIGHT=240
GESTURE_PROCESS_INTERVAL_SECONDS=0.12
GESTURE_PREVIEW_INTERVAL_SECONDS=0.20
